# lumenc.lm: The self-hosted Lumen compiler!
# Memory map mirrors the seed's proven layout (SRC 100000, SYMBOLS 170000, params/locals
# 177000/177500, FIXUPS 178000, TOKENS 299000, literal heap 488000) so a self-compile fits;
# only CODE (211328) differs, because the seed's CODE_BASE holds this compiler's own IR.
# (D4: SYMBOLS/PARAMS/LOCALS/FIXUPS shifted +20000 from the pre-Dec layout to widen SRC to
# 70000 bytes -- lumenc.lm itself, now with Dec support, exceeds the old 50000-byte SRC cap
# when it compiles itself.
# GAP-A fix (native/selfcompile_diff.mjs): the earlier D4 pass shifted VARIANTS/PTYPES/LTYPES/
# RETTYPES/FIELDS/RECTYPES/DIAG/TOKENS by +100000 (270000->370000 etc) to give CODE's growth
# room, but the literal-heap start (set_hp's initial value in lex_compile) is baked into every
# compiled program's own emitted IR as an absolute address (string-literal pointers are
# compile-time-resolved constants, not relocatable offsets) and so MUST stay pinned at the
# seed's own 488000 -- it cannot shift the way the other regions did. That pinned ceiling
# capped TOKENS at [396000,488000) = 92000 bytes = 7666 tokens, silently below what a
# real self-hosted compile needs (native/emit_fn.lm: 7903 tokens; native/emit_llvm.lm: 12604;
# lumenc.lm compiling itself: 14420) -- tokens at index >=7666 were silently clobbered by the
# literal-heap bump allocator (heap and TOKENS are different regions, but TOKENS's own upper
# end had crept forward to overlap the pinned heap start) the moment the FIRST string literal
# was emitted during parse. Lexing itself stayed correct (every token is written up front,
# before any heap bump happens, so token COUNTS always matched the seed exactly); the
# corruption only surfaced once parsing walked far enough into the file to re-read an
# already-clobbered token, manifesting as a handful of parse-recovery diagnostics (E0001/E0004)
# with garbage spans, never as a lex-level divergence.
# Fix: CODE's own reserved room was 39668 words (158672 bytes) but self-compiling lumenc.lm
# (the largest of the four toolchain sources) needs only 16503 -- CODE was over-provisioned by
# more than 2x. Shrinking CODE's reserved room to 19668 words (78672 bytes, still +19% headroom
# over the 16503 high-water mark) and repacking VARIANTS/PTYPES/LTYPES/RETTYPES/FIELDS/RECTYPES/
# DIAG immediately after it (each kept at least as large as before; RECTYPES/DIAG, both
# originally sized for far more entries than any of these files ever registers, are trimmed to
# still-generous fixed sizes) reclaims enough of that slack to widen TOKENS to
# [299000,488000) = 189000 bytes = 15750 tokens (+9% headroom over the 14420 high-water mark)
# without moving the pinned heap start and without changing a single baked address in any
# emitted program. See native_resident_test.mjs / native_fixpoint_test.mjs / selfhost_diff.mjs
# SELF(lumenc.lm) for the self-compile bit-identity this must keep holding.
fn SRC() -> Int { return 100000 }
fn TOKENS() -> Int { return 299000 }
fn SYMBOLS() -> Int { return 170000 }
fn PARAMS() -> Int { return 177000 }
# LOCALS (D6, GAP-A prefix-bisect find): entries are 8 bytes (name_off, name_len), get_nlocal()
# resets to 0 at the start of EVERY function (c_fn, set_nlocal(0)) and never shrinks again until
# the next fn - so its true capacity requirement is "however many distinct `let`/`var` bindings
# the single largest function in any toolchain source declares", not a whole-program budget.
# The old span [177500,178000) = 500 bytes = 62 slots was fine for ordinary functions but
# native/emit_llvm.lm's emit_op() (one giant per-opcode dispatch, ~70 `if op == N` arms sharing
# one function body) declares 163 distinct locals across its lifetime. Slot 63 onward silently
# overran into FIXUPS' own (pos, off, len) records starting at the old 178000, corrupting
# in-flight fixups with garbage (off, len) pairs that -- by coincidence, since a local's own
# (off, len) IS a valid-looking (off, len) once misread as a fixup record's tail -- decoded as
# plausible-looking but bogus forward-reference names ('reg2', 'hi', 'rshift', 'rovf', ...),
# so resolve_fixups's sym_find() correctly failed to find a "function" by that name and emitted
# a real but SPURIOUS E0002 "unknown function" for each one (68 on the actual file; the found
# minimal repro is emit_llvm.lm's emit_op alone). Symptom only appears on this one huge function
# because none of the toolchain's other functions declare anywhere near 62 locals - the earlier
# GAP-A tests never exercised this ceiling.
# Fix: widen LOCALS to 4000 bytes (500 slots, +207% over the 163 high-water mark) by pushing
# FIXUPS from 178000 to 181500 - FIXUPS's real ceiling is CODE at 211328 (not TOKENS, which
# sits much further out at 299000, past CODE/VARIANTS/PTYPES/etc.), so [181500,211328) =
# 29828 bytes = 2485 fixup slots is still enormous headroom versus the dozens any file
# actually needs, and nothing downstream of FIXUPS had to move.
fn LOCALS() -> Int { return 177500 }
fn FIXUPS() -> Int { return 181500 }
fn CODE() -> Int { return 211328 }
fn HEAP() -> Int { return 400000 }
# sum-type variant table: (name_off, name_len, tag) x 12 bytes, immediately after CODE's
# (shrunk but still generous) reserved room and well clear of the DIAG_BASE error records.
fn VARIANTS() -> Int { return 290000 }
fn VARIANT_OK_LIT() -> Int { return 291000 }
fn VARIANT_ERR_LIT() -> Int { return 291010 }
# static-type side tables (4 bytes per entry, parallel to PARAMS/LOCALS/SYMBOLS): 0 = Int/Text/
# other, 1 = Float - the only distinction the IR's TYPEMAP (op 57) and coercion rules need.
fn PTYPES() -> Int { return 292000 }
fn LTYPES() -> Int { return 293000 }
fn RETTYPES() -> Int { return 294000 }
# record tables, mirroring the seed's GLOBAL field model: fields are numbered by NAME across
# all record types, first registration wins (index AND type). FIELDS entries are
# (name_off, name_len, ftype) x 12 bytes, the entry position IS the global field index.
# RECTYPES entries are (name_off, name_len, arity) x 12 bytes, where arity is
# max(global index of the type's own fields) + 1 - the array size a construction allocates.
# (Trimmed from the pre-GAP-A 14000-byte/1166-entry size to 1000 bytes/83 entries: still far
# more record types than any toolchain source declares, and the reclaimed 13000 bytes goes to
# TOKENS above.)
fn FIELDS() -> Int { return 295000 }
fn RECTYPES() -> Int { return 296000 }

# Globals mapped to memory [0..1024)
fn get_emit() -> Int { return load32(0) }
fn set_emit(v: Int) -> Unit { store32(0, v) }

fn get_tp() -> Int { return load32(4) }
fn set_tp(v: Int) -> Unit { store32(4, v) }

fn get_ntok() -> Int { return load32(8) }
fn set_ntok(v: Int) -> Unit { store32(8, v) }

fn get_nsym() -> Int { return load32(12) }
fn set_nsym(v: Int) -> Unit { store32(12, v) }

fn get_nparam() -> Int { return load32(16) }
fn set_nparam(v: Int) -> Unit { store32(16, v) }

fn get_nlocal() -> Int { return load32(20) }
fn set_nlocal(v: Int) -> Unit { store32(20, v) }

fn get_nfixup() -> Int { return load32(24) }
fn set_nfixup(v: Int) -> Unit { store32(24, v) }

fn get_nerr() -> Int { return load32(28) }
fn set_nerr(v: Int) -> Unit { store32(28, v) }

fn get_hp() -> Int { return load32(32) }
fn set_hp(v: Int) -> Unit { store32(32, v) }

fn get_main_entry() -> Int { return load32(36) }
fn set_main_entry(v: Int) -> Unit { store32(36, v) }

fn get_expr_pushes() -> Int { return load32(40) }
fn set_expr_pushes(v: Int) -> Unit { store32(40, v) }

fn get_discard_slot() -> Int { return load32(44) }
fn set_discard_slot(v: Int) -> Unit { store32(44, v) }

fn get_nvariant() -> Int { return load32(56) }
fn set_nvariant(v: Int) -> Unit { store32(56, v) }

# static type of the most recently compiled expression (0 = Int/Text/other, 1 = Float)
fn get_etype() -> Int { return load32(60) }
fn set_etype(v: Int) -> Unit { store32(60, v) }

# result registers of float_bits(): the two i32 words of a parsed float literal's f64 bits
fn get_flo() -> Int { return load32(64) }
fn set_flo(v: Int) -> Unit { store32(64, v) }
fn get_fhi() -> Int { return load32(68) }
fn set_fhi(v: Int) -> Unit { store32(68, v) }

fn get_nfield() -> Int { return load32(72) }
fn set_nfield(v: Int) -> Unit { store32(72, v) }
fn get_nrectype() -> Int { return load32(76) }
fn set_nrectype(v: Int) -> Unit { store32(76, v) }

# ---------- small helpers ----------
fn b(i: Int) -> Int {
  return load8(SRC() + i)
}

fn is_digit(c: Int) -> Int {
  if c >= 48 { if c <= 57 { return 1 } }
  return 0
}

fn is_alpha(c: Int) -> Int {
  if c >= 65 { if c <= 90 { return 1 } }
  if c >= 97 { if c <= 122 { return 1 } }
  if c == 95 { return 1 }
  return 0
}

# true if source byte i is 'd' AND not immediately followed by an identifier-continuation
# character, so a number directly abutting an identifier (e.g. a typo like 1death) is not
# silently swallowed as a Dec literal + garbage; it lexes as before (INT then IDENT) and
# fails to parse, exactly matching the seed's own $is_d_suffix contract.
fn is_d_suffix(i: Int, srclen: Int) -> Int {
  if i >= srclen { return 0 }
  if b(i) != 100 { return 0 }
  if i + 1 < srclen {
    let nc = b(i + 1)
    if is_alpha(nc) == 1 { return 0 }
    if is_digit(nc) == 1 { return 0 }
  }
  return 1
}

fn streq(p1: Int, p2: Int, len: Int) -> Int {
  var i = 0
  while i < len {
    if load8(p1 + i) != load8(p2 + i) {
      return 0
    }
    i = i + 1
  }
  return 1
}

fn eqlit(off: Int, len: Int, p: Int, plen: Int) -> Int {
  if len != plen { return 0 }
  return streq(off, p, len)
}

# token accessors. SAFETY (mirrors the seed .wat's $tk/$ta/$tb): any index at or past
# get_ntok() reads as EOF (kind 14, payload 0), so every `tk==14` guard correctly detects
# end-of-stream and no parser loop can walk past the token region into stale/unwritten
# memory from a prior compile (which is what let an unbalanced-brace input like an
# `else if` mishandled elsewhere spin forever instead of raising E0004).
fn tk(i: Int) -> Int { if i >= get_ntok() { return 14 } return load32(TOKENS() + i * 12) }
fn ta(i: Int) -> Int { if i >= get_ntok() { return 0 } return load32(TOKENS() + i * 12 + 4) }
fn tb(i: Int) -> Int { if i >= get_ntok() { return 0 } return load32(TOKENS() + i * 12 + 8) }
fn tokset(i: Int, k: Int, a: Int, bb: Int) -> Unit {
  let base = TOKENS() + i * 12
  store32(base, k)
  store32(base + 4, a)
  store32(base + 8, bb)
}

fn is_str_main(off: Int, len: Int) -> Int {
  if len != 4 { return 0 }
  if load8(off + 0) != 109 { return 0 }
  if load8(off + 1) != 97 { return 0 }
  if load8(off + 2) != 105 { return 0 }
  if load8(off + 3) != 110 { return 0 }
  return 1
}
fn is_kw_main(i: Int) -> Int {
  if tk(i) != 1 { return 0 }
  return is_str_main(ta(i), tb(i))
}

