fn weekday(year: Int, month: Int, day: Int, console: Console) -> Unit {
  var y = year
  var m = month
  if m < 3 {
    y = y - 1
    m = m + 12
  }
  let c = y / 100
  let yy = y - c * 100
  let raw = day + ((m + 1) * 26) / 10 + yy + yy / 4 + c / 4 + 5 * c
  let h = raw - (raw / 7) * 7
  console.print_int(h)
}

fn main(console: Console) -> Unit {
  weekday(2000, 1, 1, console)
  weekday(2026, 7, 15, console)
  weekday(1900, 3, 1, console)
}
