fn is_str_text_concat(off: Int, len: Int) -> Int {
  if len != 11 { return 0 }
  if load8(off + 0) != 116 { return 0 }
  if load8(off + 1) != 101 { return 0 }
  if load8(off + 2) != 120 { return 0 }
  if load8(off + 3) != 116 { return 0 }
  if load8(off + 4) != 95 { return 0 }
  if load8(off + 5) != 99 { return 0 }
  if load8(off + 6) != 111 { return 0 }
  if load8(off + 7) != 110 { return 0 }
  if load8(off + 8) != 99 { return 0 }
  if load8(off + 9) != 97 { return 0 }
  if load8(off + 10) != 116 { return 0 }
  return 1
}
fn is_kw_text_concat(i: Int) -> Int {
  if tk(i) != 1 { return 0 }
  return is_str_text_concat(ta(i), tb(i))
}

