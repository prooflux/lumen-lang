    let reg3 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = and i64 %r") num(c, reg1) c.print(", %r") num(c, reg2) c.print("\n")
    c.print("  store i64 %r") num(c, reg3) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 59 {
    let reg1 = ld_as_int(c, d - 2)
    let reg2 = ld_as_int(c, d - 1)
    let reg3 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = or i64 %r") num(c, reg1) c.print(", %r") num(c, reg2) c.print("\n")
    c.print("  store i64 %r") num(c, reg3) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 60 {
    let reg1 = ld_as_int(c, d - 2)
    let reg2 = ld_as_int(c, d - 1)
    let reg3 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = xor i64 %r") num(c, reg1) c.print(", %r") num(c, reg2) c.print("\n")
    c.print("  store i64 %r") num(c, reg3) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 61 {
    let reg1 = ld_as_int(c, d - 2)
    let reg2 = ld_as_int(c, d - 1)
    let reg3 = get_reg()
    let reg4 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = and i64 %r") num(c, reg2) c.print(", 63\n")
    c.print("  %r") num(c, reg4) c.print(" = shl i64 %r") num(c, reg1) c.print(", %r") num(c, reg3) c.print("\n")
    c.print("  store i64 %r") num(c, reg4) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 62 {
    let reg1 = ld_as_int(c, d - 2)
    let reg2 = ld_as_int(c, d - 1)
    let reg3 = get_reg()
    let reg4 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = and i64 %r") num(c, reg2) c.print(", 63\n")
    c.print("  %r") num(c, reg4) c.print(" = lshr i64 %r") num(c, reg1) c.print(", %r") num(c, reg3) c.print("\n")
    c.print("  store i64 %r") num(c, reg4) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 63 {
    let reg1 = ld_as_int(c, d - 1)
    let reg2 = get_reg()
    c.print("  %r") num(c, reg2) c.print(" = xor i64 %r") num(c, reg1) c.print(", -1\n")
    c.print("  store i64 %r") num(c, reg2) c.print(", ptr %s") num(c, d - 1) c.print(", align 8\n")
    set_sty(d - 1, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d
  }

  c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
  return d
}

fn emit_bodies(c: Console) -> Unit {
  var pc = 0
  var first = 1
  var d = 0
  var resetnext = 0
  var func_pc = 0
  while pc < ir_len() {
    let op = ir_word(pc)
    if op == 13 {
      if first == 0 {
        c.print("}\n")
      }
      first = 0
      func_pc = pc

      let fs = ir_word(pc + 1)
      let arity = arity_of(pc)
      let md = max_depth(pc)
      let ret_t = rettype_of(pc)
      let mf = max_field(pc)
      var fs_val = fs
      if fs_val < 1 { fs_val = 1 }
      if mf + 1 > fs_val { fs_val = mf + 1 }

      if ret_t == 1 { c.print("define double @f") num(c, pc) c.print("(") }
      else { c.print("define i64 @f") num(c, pc) c.print("(") }
      var j = 0
      while j < arity {
        if j > 0 { c.print(", ") }
        if type_of_slot(pc, j) == 1 { c.print("double %p") num(c, j) }
        else { c.print("i64 %p") num(c, j) }
        j = j + 1
      }
      c.print(") {\n")
      c.print("entry:\n")

      var md_val = md
      if md_val < 1 { md_val = 1 }
      j = 0
      while j < md_val {
        c.print("  %s") num(c, j) c.print(" = alloca i64, align 8\n")
        c.print("  %sd") num(c, j) c.print(" = alloca double, align 8\n")
        j = j + 1
      }

      j = 0
      while j < fs_val {
        if type_of_slot(pc, j) == 1 { c.print("  %F") num(c, j) c.print(" = alloca double, align 8\n") }
        else { c.print("  %F") num(c, j) c.print(" = alloca i64, align 8\n") }
        j = j + 1
      }

      j = 0
      while j < fs_val {
        if type_of_slot(pc, j) == 1 { c.print("  store double 0.000000e+00, ptr %F") num(c, j) c.print(", align 8\n") }
        else { c.print("  store i64 0, ptr %F") num(c, j) c.print(", align 8\n") }
        j = j + 1
      }

      j = 0
      while j < arity {
        if type_of_slot(pc, j) == 1 { c.print("  store double %p") num(c, j) c.print(", ptr %F") num(c, j) c.print(", align 8\n") }
        else { c.print("  store i64 %p") num(c, j) c.print(", ptr %F") num(c, j) c.print(", align 8\n") }
        j = j + 1
      }

      reset_reg()

      let resolved_start = resolve_pc(pc + 2)
      c.print("  br label %L") num(c, resolved_start) c.print("\n")

      d = 0
      resetnext = 0
      pc = pc + 2
    } else {
      if op == 57 {
        pc = pc + 3 + ir_word(pc + 1)
      } else {
        if resetnext == 1 { d = 0 resetnext = 0 }
        d = emit_op(c, pc, d, func_pc)
        if op == 0 { resetnext = 1 }
        if op == 7 { resetnext = 1 }
        if op == 9 { resetnext = 1 }
        pc = pc + 1 + oplen(op)
      }
    }
  }
  if first == 0 {
    c.print("}\n")
  }
}

fn main(c: Console) -> Unit {
  scan_arity()

  c.print("target triple = ")
  print_quote(c)
  c.print("arm64-apple-macosx")
  print_quote(c)
  c.print("\n")

  c.print("@fmt_int = private unnamed_addr constant [6 x i8] c")
  print_quote(c)
  c.print("%lld\0A\00")
  print_quote(c)
  c.print(", align 1\n")

  c.print("declare i32 @printf(ptr, ...)\n")
  c.print("declare void @exit(i32)\n")
  c.print("declare i32 @fflush(ptr)\n")
  c.print("declare void @abort()\n")

  c.print("declare void @lm_printtext(i64)\n")
  c.print("declare i64 @lm_concat(i64, i64)\n")
  c.print("declare i64 @lm_int2text(i64)\n")
  c.print("declare i64 @lm_alloc_sum(i64, i64)\n")
  c.print("declare i64 @lm_texteq(i64, i64)\n")
  c.print("declare i64 @lm_anew(i64)\n")
  c.print("declare i64 @lm_aget(i64, i64)\n")
  c.print("declare void @lm_aset(i64, i64, i64)\n")
  c.print("declare i64 @lm_alen(i64)\n")

  c.print("declare i64 @llvm.fptosi.sat.i64.f64(double)\n")
  c.print("declare double @llvm.roundeven.f64(double)\n")
  c.print("declare double @llvm.floor.f64(double)\n")
  c.print("declare double @llvm.sqrt.f64(double)\n")
  c.print("declare double @llvm.fabs.f64(double)\n")
  emit_f_exp(c)
  emit_f_ln(c)
  emit_f_pow(c)

  emit_static_strings(c)

  c.print("define i32 @main() {\n")
  c.print("  %ignored = call i64 @f") num(c, ir_main()) c.print("()\n")
  c.print("  ret i32 0\n")
  c.print("}\n")

  emit_bodies(c)
}
