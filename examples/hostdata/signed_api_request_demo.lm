# STATUS: this demo's one signature was independently verified valid (see
# rsa_pss_kernel.lm's header for the full verification-status caveat - the underlying kernel
# is proven correct on this one case, not yet across a broad vector suite).
#
# signed_api_request_demo.lm - end-to-end demo: Lumen signing a realistic generic REST API
# request with RSA-PSS-SHA256, using ONLY the four from-scratch kernels proved in this
# session (SHA-256, bignum, HMAC-SHA256, RSA-PSS). No host-side crypto is called anywhere in
# this file; every byte of the signature is computed by Lumen bytecode.
#
# Scenario (generic, textbook - no real vendor/account/API is named): many REST APIs that sign
# requests with an asymmetric key use the pattern
#     message = <unix_timestamp> || <HTTP_METHOD> || <request_path>
# concatenated as ASCII text, then sign that message string. This demo reproduces exactly that
# pattern:
#     unix_timestamp = 1735689600   (2025-01-01T00:00:00Z, a fixed illustrative timestamp)
#     HTTP_METHOD    = "POST"
#     path           = "/v1/orders"
#     message        = "1735689600POST/v1/orders"
# and signs it with RSA-PSS-SHA256 (MGF1(SHA-256), salt length 32) using a throwaway 768-bit
# RSA key generated once for this demo (n, e, d below; NOT used for anything else, safe to
# publish). The fixed salt (32 bytes, value = index 0..31) is the same deterministic test salt
# used by rsa_pss_verify.py, so the signature this program prints is reproducible run to run.
#
# This file inlines the entire rsa_pss_kernel.lm kernel body (bignum + SHA-256 + MGF1 +
# EMSA-PSS-ENCODE + RSASP1) verbatim - this Lumen subset has no cross-file import mechanism -
# and appends one new main() below the "DEMO" marker that builds the request message, the key
# limbs, and the fixed salt, then calls rsa_pss_sign and prints the signature as hex.
#
# Key material (RFC 8017 n/e/d triple), for reference and for the Python verification harness
# to reconstruct the same key independently of this file:
#   n = 1267236768047709670373609944667646848842471259230921441845371184753743710929455486044352160574509473983501208491913282348454611528853611438256027647066344400264714060042072053165619201688572600818894406379602696485357059033945212597
#   e = 65537
#   d = 636393129224502505017566420478532631782098876723195851107234942591440148528468482791273911055255135385278419425451998183236808754962159039378241816905389804931206420354002565102906462421460862869280095391614097998939810018164669953
# n bit length = 768 (24 limbs of 32 bits, little-endian, the same NLIMBS=24/MOD_BITS=768
# convention rsa_pss_verify.py uses). Int in this Lumen subset is 64-bit, so a 768-bit integer
# cannot be a single Lumen Int literal; n/e/d are supplied below as their limb decomposition,
# computed once from the literal integers above and hardcoded (see bytes_to_bignum / limbs_le
# in rsa_pss_verify.py for the general recipe: limb i = (x >> (32*i)) & 0xFFFFFFFF).

# rsa_pss_kernel.lm - RSA-PSS SIGNING (RFC 8017: RSASP1 + MGF1 + EMSA-PSS-ENCODE, hash =
# SHA-256), implemented from scratch in pure Lumen. Self-contained: inlines the bignum kernel
# (examples/hostdata/bignum_kernel.lm) and the SHA-256 kernel (examples/hostdata/sha256_kernel.lm)
# verbatim, then adds the PSS/MGF1/RSASP1 glue on top.
#
# Scope (explicitly out of scope per the build brief): NO PEM/DER parsing. Key material (the
# modulus n, the public exponent e, and the private exponent d) is supplied to `rsa_pss_sign`
# already decomposed into little-endian 32-bit-limb Int arrays - the same representation
# `bignum_kernel.lm` uses everywhere else. The caller (the Python verification harness) is
# responsible for extracting those integers from a real key and slicing them into limbs.
#
# Determinism: RFC 8017 PSS signing normally draws a fresh random salt per signature. This
# kernel takes the salt as an EXPLICIT INPUT byte array instead of generating one internally,
# so a fixed test salt reproduces a fixed signature - required for a deterministic test harness
# (a real deployment would instead pass in output from a CSPRNG at the call site).
#
# Size note: the modulus bit width `mod_bits` and the limb count `nlimbs` are both parameters,
# not hardcoded, so this same code runs at any key size the caller allocates arrays for (the
# verification harness below uses a 512-bit modulus, 16 limbs, the smallest size Python's
# `cryptography` library's `rsa.generate_private_key` accepts).

# ===========================================================================
# Section 1: bignum kernel (inlined verbatim from bignum_kernel.lm)
# ===========================================================================

fn bn_zero(a: Int, n: Int) -> Unit {
  var i: Int = 0
  while i < n {
    iaset(a, i, 0)
    i = i + 1
  }
  return ()
}

fn bn_copy(src: Int, dst: Int, n: Int) -> Unit {
  var i: Int = 0
  while i < n {
    iaset(dst, i, iaget(src, i))
    i = i + 1
  }
  return ()
}

fn bn_cmp(a: Int, b: Int, n: Int) -> Int {
  var i: Int = n - 1
  var result: Int = 0
  var deciding: Int = 1
  while i >= 0 {
    if deciding == 1 {
      let av = iaget(a, i)
      let bv = iaget(b, i)
      if av > bv {
        result = 1
        deciding = 0
      } else {
        if av < bv {
          result = -1
          deciding = 0
        }
      }
    }
    i = i - 1
  }
  return result
}

fn bn_add(a: Int, b: Int, out: Int, n: Int) -> Int {
  var carry: Int = 0
  var i: Int = 0
  while i < n {
    let s = iaget(a, i) + iaget(b, i) + carry
    iaset(out, i, band(s, 4294967295))
    carry = shr(s, 32)
    i = i + 1
  }
  return carry
}

fn bn_sub(a: Int, b: Int, out: Int, n: Int) -> Int {
  var borrow: Int = 0
  var i: Int = 0
  while i < n {
    var d: Int = iaget(a, i) - iaget(b, i) - borrow
    if d < 0 {
      d = d + 4294967296
      borrow = 1
    } else {
      borrow = 0
    }
    iaset(out, i, d)
    i = i + 1
  }
  return borrow
}

fn bn_get_bit(a: Int, n: Int, i: Int) -> Int {
  let limb_idx = i / 32
  let bit_idx = i % 32
  return band(shr(iaget(a, limb_idx), bit_idx), 1)
}

fn bn_shl1(a: Int, n: Int) -> Int {
  var carry_in: Int = 0
  var i: Int = 0
  while i < n {
    let limb = iaget(a, i)
    let bit_out = band(shr(limb, 31), 1)
    let new_limb = bor(band(shl(limb, 1), 4294967295), carry_in)
    iaset(a, i, new_limb)
    carry_in = bit_out
    i = i + 1
  }
  return carry_in
}

fn bn_mul(a: Int, b: Int, out: Int, n: Int) -> Unit {
  bn_zero(out, 2 * n)
  var i: Int = 0
  while i < n {
    var carry: Int = 0
    var j: Int = 0
    while j < n {
      let prod = iaget(a, i) * iaget(b, j)
      let s = prod + iaget(out, i + j) + carry
      iaset(out, i + j, band(s, 4294967295))
      carry = shr(s, 32)
      j = j + 1
    }
    var k: Int = i + n
    var c: Int = carry
    while c > 0 {
      let s2 = iaget(out, k) + c
      iaset(out, k, band(s2, 4294967295))
      c = shr(s2, 32)
      k = k + 1
    }
    i = i + 1
  }
  return ()
}

fn bn_mod(a: Int, alen: Int, m: Int, n: Int, r: Int) -> Unit {
  bn_zero(r, n)
  var i: Int = alen * 32 - 1
  while i >= 0 {
    let carry_bit = bn_shl1(r, n)
    let a_bit = bn_get_bit(a, alen, i)
    iaset(r, 0, bor(iaget(r, 0), a_bit))
    if carry_bit == 1 {
      bn_sub(r, m, r, n)
    } else {
      if bn_cmp(r, m, n) >= 0 {
        bn_sub(r, m, r, n)
      }
    }
    i = i - 1
  }
  return ()
}

fn bn_modpow(base: Int, exp: Int, m: Int, n: Int, result: Int) -> Unit {
  let base_cur = iarray(n)
  bn_mod(base, n, m, n, base_cur)

  bn_zero(result, n)
  iaset(result, 0, 1)

  let sq = iarray(2 * n)
  let sq_mod = iarray(n)
  let mul_buf = iarray(2 * n)
  let mul_mod = iarray(n)

  var i: Int = n * 32 - 1
  while i >= 0 {
    bn_mul(result, result, sq, n)
    bn_mod(sq, 2 * n, m, n, sq_mod)
    bn_copy(sq_mod, result, n)

    if bn_get_bit(exp, n, i) == 1 {
      bn_mul(result, base_cur, mul_buf, n)
      bn_mod(mul_buf, 2 * n, m, n, mul_mod)
      bn_copy(mul_mod, result, n)
    }
    i = i - 1
  }
  return ()
}

fn bn_print(console: Console, a: Int, n: Int) -> Unit {
  var i: Int = 0
  while i < n {
    console.print_int(iaget(a, i))
    i = i + 1
  }
  return ()
}

# ===========================================================================
# Section 2: SHA-256 kernel (inlined verbatim from sha256_kernel.lm)
# ===========================================================================

fn mask32(x: Int) -> Int {
  return band(x, 4294967295)
}

fn add32(a: Int, b: Int) -> Int {
  return mask32(a + b)
}

fn add32_4(a: Int, b: Int, c: Int, d: Int) -> Int {
  return add32(add32(add32(a, b), c), d)
}

fn rotr(x: Int, n: Int) -> Int {
  return bor(shr(x, n), mask32(shl(x, 32 - n)))
}

fn ch(x: Int, y: Int, z: Int) -> Int {
  return bxor(band(x, y), band(bnot(x), z))
}

fn maj(x: Int, y: Int, z: Int) -> Int {
  return bxor(bxor(band(x, y), band(x, z)), band(y, z))
}

fn big_sigma0(x: Int) -> Int {
  return bxor(bxor(rotr(x, 2), rotr(x, 13)), rotr(x, 22))
}

fn big_sigma1(x: Int) -> Int {
  return bxor(bxor(rotr(x, 6), rotr(x, 11)), rotr(x, 25))
}

fn small_sigma0(x: Int) -> Int {
  return bxor(bxor(rotr(x, 7), rotr(x, 18)), shr(x, 3))
}

fn small_sigma1(x: Int) -> Int {
  return bxor(bxor(rotr(x, 17), rotr(x, 19)), shr(x, 10))
}

fn make_k() -> Array {
