# KNOWN ISSUE (found by adversarial re-verification, 2026-07-23 - NOT yet patched): with a
# 32- or 64-byte key, messages beyond ~886 bytes make the seed interpreter halt with EXIT 0
# and ZERO output (no crash, no error). Root-caused to the SAME shared, never-freed Lumen
# array/Text heap ceiling documented in examples/hostdata/json_kernel.lm's header (a runtime
# limitation, not an HMAC or SHA-256 algorithm bug - the inner SHA-256 core, verified in
# isolation on the same message lengths, is correct; the failure is specifically in the
# final outer sha256_hex call once cumulative heap usage crosses the ceiling). Do not rely
# on this kernel for messages beyond a few hundred bytes until the runtime heap limit is
# fixed or made to fail loudly. See examples/hostdata/README.md for the full writeup.
#
# HMAC-SHA256 (RFC 2104 / FIPS 198-1), implemented from scratch in pure Lumen.
#
# This file is self-contained: it inlines the entire SHA-256 kernel from
# examples/hostdata/sha256_kernel.lm (that kernel was built and verified separately; its
# logic is reused verbatim here, not reimplemented) because this Lumen subset has no
# cross-file import mechanism (confirmed absent in the build brief). The only functional
# addition beyond the SHA-256 kernel is:
#   - sha256_words: same pipeline as sha256_hex but returns the raw 8 Int words instead of
#     formatting them to hex, so the inner HMAC hash can be fed as raw bytes into the outer
#     hash without a hex round-trip.
#   - words_to_bytes / concat_bytes: byte-array plumbing to build ipad||message and
#     opad||inner_hash per RFC 2104.
#   - hmac_sha256_hex: the HMAC construction itself.
#
# Input representation: key and message are each a Lumen Int array of byte values (0..255)
# plus an explicit length, exactly like sha256_kernel.lm's `msg`/`msg_len`. Output is a
# 64-character lowercase hex Text, matching Python's `hmac.new(key, msg,
# hashlib.sha256).hexdigest()`.

fn mask32(x: Int) -> Int {
  return band(x, 4294967295)
}

fn add32(a: Int, b: Int) -> Int {
  return mask32(a + b)
}

fn add32_4(a: Int, b: Int, c: Int, d: Int) -> Int {
  return add32(add32(add32(a, b), c), d)
}

fn rotr(x: Int, n: Int) -> Int {
  return bor(shr(x, n), mask32(shl(x, 32 - n)))
}

fn ch(x: Int, y: Int, z: Int) -> Int {
  return bxor(band(x, y), band(bnot(x), z))
}

fn maj(x: Int, y: Int, z: Int) -> Int {
  return bxor(bxor(band(x, y), band(x, z)), band(y, z))
}

fn big_sigma0(x: Int) -> Int {
  return bxor(bxor(rotr(x, 2), rotr(x, 13)), rotr(x, 22))
}

fn big_sigma1(x: Int) -> Int {
  return bxor(bxor(rotr(x, 6), rotr(x, 11)), rotr(x, 25))
}

fn small_sigma0(x: Int) -> Int {
  return bxor(bxor(rotr(x, 7), rotr(x, 18)), shr(x, 3))
}

fn small_sigma1(x: Int) -> Int {
  return bxor(bxor(rotr(x, 17), rotr(x, 19)), shr(x, 10))
}

