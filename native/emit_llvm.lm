fn hdr() -> Int { return 524288 }
fn ir_len() -> Int { return load32(hdr()) }
fn ir_main() -> Int { return load32(hdr() + 4) }
fn ir_word(i: Int) -> Int { return load32(hdr() + 8 + i * 4) }
fn arity_base() -> Int { return 560000 }
fn arity_of(e: Int) -> Int { return load32(arity_base() + e * 4) }

fn dir_base() -> Int { return hdr() + 8 + ir_len() * 4 }
fn dir_word_count() -> Int { return load32(dir_base()) }
fn num_strings() -> Int { return dir_word_count() / 3 }
fn dir_orig_ptr(i: Int) -> Int { return load32(dir_base() + 4 + i * 12) }
fn dir_len(i: Int) -> Int { return load32(dir_base() + 4 + i * 12 + 4) }
fn dir_byte_offset(i: Int) -> Int { return load32(dir_base() + 4 + i * 12 + 8) }

fn oplen(op: Int) -> Int {
  if op == 1 { return 1 }
  if op == 2 { return 1 }
  if op == 6 { return 1 }
  if op == 7 { return 1 }
  if op == 8 { return 2 }
  if op == 13 { return 1 }
  if op == 14 { return 1 }
  if op == 15 { return 1 }
  if op == 25 { return 1 }
  if op == 29 { return 2 }
  return 0
}

fn print_hex_byte(c: Console, b: Int) -> Unit {
  c.print("\")
  let h = b / 16
  if h == 0 { c.print("0") }
  if h == 1 { c.print("1") }
  if h == 2 { c.print("2") }
  if h == 3 { c.print("3") }
  if h == 4 { c.print("4") }
  if h == 5 { c.print("5") }
  if h == 6 { c.print("6") }
  if h == 7 { c.print("7") }
  if h == 8 { c.print("8") }
  if h == 9 { c.print("9") }
  if h == 10 { c.print("a") }
  if h == 11 { c.print("b") }
  if h == 12 { c.print("c") }
  if h == 13 { c.print("d") }
  if h == 14 { c.print("e") }
  if h == 15 { c.print("f") }
  let l = b % 16
  if l == 0 { c.print("0") }
  if l == 1 { c.print("1") }
  if l == 2 { c.print("2") }
  if l == 3 { c.print("3") }
  if l == 4 { c.print("4") }
  if l == 5 { c.print("5") }
  if l == 6 { c.print("6") }
  if l == 7 { c.print("7") }
  if l == 8 { c.print("8") }
  if l == 9 { c.print("9") }
  if l == 10 { c.print("a") }
  if l == 11 { c.print("b") }
  if l == 12 { c.print("c") }
  if l == 13 { c.print("d") }
  if l == 14 { c.print("e") }
  if l == 15 { c.print("f") }
}

fn emit_static_strings(c: Console) -> Unit {
  let num_str = num_strings()
  var i = 0
  while i < num_str {
    let orig_ptr = dir_orig_ptr(i)
    let length = dir_len(i)
    let byte_off = dir_byte_offset(i)
    c.print("@str_") num(c, orig_ptr) c.print(" = private unnamed_addr constant [") num(c, 4 + length) c.print(" x i8] c")
    print_quote(c)
    print_hex_byte(c, length % 256)
    print_hex_byte(c, (length / 256) % 256)
    print_hex_byte(c, (length / 65536) % 256)
    print_hex_byte(c, (length / 16777216) % 256)
    var j = 0
    while j < length {
      print_hex_byte(c, load8(byte_off + j))
      j = j + 1
    }
    print_quote(c)
    c.print(", align 1\n")
    i = i + 1
  }
}

fn num(c: Console, n: Int) -> Unit { c.print(int_to_text(n)) }

fn print_quote(c: Console) -> Unit {
  let ptr = 589800
  store32(ptr, 1)
  store8(ptr + 4, 34)
  c.print(ptr)
}

fn resolve_pc(target: Int) -> Int {
  var p = target
  while p < ir_len() {
    if ir_word(p) == 57 {
      p = p + 3 + ir_word(p + 1)
    } else {
      return p
    }
  }
  return p
}

fn scan_arity() -> Unit {
  var pc = 0
  while pc < ir_len() {
    let op = ir_word(pc)
    if op == 8 { store32(arity_base() + ir_word(pc + 1) * 4, ir_word(pc + 2)) }
    if op == 57 { pc = pc + 3 + ir_word(pc + 1) } else { pc = pc + 1 + oplen(op) }
  }
}

fn get_reg() -> Int {
  let r = load32(589820)
  store32(589820, r + 1)
  return r
}

fn reset_reg() -> Unit {
  store32(589820, 1)
}

# ---- static per-slot type metadata (function headers carry a type-tagged op57 record right
# after each op13: [57, ntot, ret_t, type0..type(ntot-1)], ret_t/typeN: 0=Int, 1=Float). These
# three scans are exact ports of emit_fn.lm's own rettype_of/type_of_slot/max_field - the field
# type table is a compile-time fact about the IR, independent of which backend reads it.
fn rettype_of(func_pc: Int) -> Int {
  var pc = func_pc + 2
  while pc < ir_len() {
    let op = ir_word(pc)
    if op == 13 { return 0 }
    if op == 57 { return ir_word(pc + 2) }
    pc = pc + 1 + oplen(op)
  }
  return 0
}

fn type_of_slot(func_pc: Int, slot: Int) -> Int {
  var pc = func_pc + 2
  while pc < ir_len() {
    let op = ir_word(pc)
    if op == 13 { return 0 }
    if op == 57 {
      let ntot = ir_word(pc + 1)
      if slot < ntot { return ir_word(pc + 3 + slot) }
      return 0
    }
    pc = pc + 1 + oplen(op)
  }
  return 0
}

fn max_field(func_pc: Int) -> Int {
  var pc = func_pc + 2
  var max_f = 0 - 1
  while pc < ir_len() {
    let op = ir_word(pc)
    if op == 13 { return max_f }
    if op == 57 { pc = pc + 3 + ir_word(pc + 1) } else {
      if op == 2 {
        let k = ir_word(pc + 1)
        if k > max_f { max_f = k }
      }
      if op == 14 {
        let k = ir_word(pc + 1)
        if k > max_f { max_f = k }
      }
      pc = pc + 1 + oplen(op)
    }
  }
  return max_f
}

# ---- dynamic per-stack-slot type shadow (mirrors emit_fn.lm's get_sty/set_sty). Operand-stack
# slot N gets TWO allocas in the emitted function (%sN i64, %sdN double); this table is a
# COMPILE-TIME simulation (part of this emitter's own bookkeeping, not the output program) of
# which alloca currently holds the live value for slot N, tracked linearly as emission walks the
# IR in program order - the same technique emit_fn.lm already relies on for its C output.
fn sty_base() -> Int { return 586000 }
fn get_sty(k: Int) -> Int { return load8(sty_base() + k) }
fn set_sty(k: Int, t: Int) -> Unit { store8(sty_base() + k, t) }

# Read stack slot k as an i64, materializing a bitcast if the slot's live shadow is currently the
# double alloca (mirrors emit_fn.lm's sl_int's d2l fallback). k<0 is the defensive "no value"
# case (mirrors slot 0 / literal-0 fallback in emit_fn.lm; never hit by well-typed programs).
fn ld_as_int(c: Console, k: Int) -> Int {
  if k < 0 {
    let r = get_reg()
    c.print("  %r") num(c, r) c.print(" = add i64 0, 0\n")
    return r
  }
  let t = get_sty(k)
  let r0 = get_reg()
  if t == 1 {
    c.print("  %r") num(c, r0) c.print(" = load double, ptr %sd") num(c, k) c.print(", align 8\n")
    let r1 = get_reg()
    c.print("  %r") num(c, r1) c.print(" = bitcast double %r") num(c, r0) c.print(" to i64\n")
    return r1
  }
  c.print("  %r") num(c, r0) c.print(" = load i64, ptr %s") num(c, k) c.print(", align 8\n")
  return r0
}

# Read stack slot k as a double, materializing a bitcast if the slot's live shadow is currently
# the int alloca (mirrors emit_fn.lm's sl_double's l2d fallback).
fn ld_as_double(c: Console, k: Int) -> Int {
  if k < 0 {
    let r = get_reg()
    c.print("  %r") num(c, r) c.print(" = fadd double 0.000000e+00, 0.000000e+00\n")
    return r
  }
  let t = get_sty(k)
  let r0 = get_reg()
  if t == 0 {
    c.print("  %r") num(c, r0) c.print(" = load i64, ptr %s") num(c, k) c.print(", align 8\n")
    let r1 = get_reg()
    c.print("  %r") num(c, r1) c.print(" = bitcast i64 %r") num(c, r0) c.print(" to double\n")
    return r1
  }
  c.print("  %r") num(c, r0) c.print(" = load double, ptr %sd") num(c, k) c.print(", align 8\n")
  return r0
}

fn st_int(c: Console, k: Int, reg: Int) -> Unit {
  var kk = k
  if kk < 0 { kk = 0 }
  c.print("  store i64 %r") num(c, reg) c.print(", ptr %s") num(c, kk) c.print(", align 8\n")
  set_sty(kk, 0)
}

fn st_double(c: Console, k: Int, reg: Int) -> Unit {
  var kk = k
  if kk < 0 { kk = 0 }
  c.print("  store double %r") num(c, reg) c.print(", ptr %sd") num(c, kk) c.print(", align 8\n")
  set_sty(kk, 1)
}

fn oplen_d_change(op: Int, pc: Int, d: Int) -> Int {
  if op == 1 { return d + 1 }
  if op == 2 { return d + 1 }
  if op == 3 { return d - 1 }
  if op == 4 { return d - 1 }
  if op == 5 { return d - 1 }
  if op == 6 { return d - 1 }
  if op == 8 {
    let argc = ir_word(pc + 2)
    return d - argc + 1
  }
  if op == 10 { return d - 1 }
  if op == 11 { return d - 1 }
  if op == 12 { return d - 1 }
  if op == 14 { return d - 1 }
  if op == 15 { return d + 1 }
  if op == 16 { return d - 1 }
  if op == 17 { return d - 1 }
  if op == 19 { return d - 1 }
  if op == 20 { return d - 1 }
  if op == 21 { return d - 1 }
  if op == 22 { return d - 1 }
  if op == 23 { return d - 1 }
  if op == 24 { return d - 1 }
  if op == 28 { return d - 1 }
  if op == 29 { return d + 1 }
  if op == 30 { return d }
  if op == 31 { return d }
  if op == 32 { return d - 1 }
  if op == 33 { return d - 1 }
  if op == 34 { return d - 1 }
  if op == 35 { return d - 1 }
  if op == 36 { return d - 1 }
  if op == 37 { return d - 1 }
  if op == 38 { return d - 1 }
  if op == 39 { return d - 1 }
  if op == 40 { return d - 1 }
  if op == 41 { return d - 1 }
  if op == 42 { return d }
  if op == 43 { return d }
  if op == 44 { return d }
  if op == 45 { return d }
  if op == 46 { return d }
  if op == 47 { return d }
  if op == 48 { return d - 1 }
  if op == 49 { return d }
  if op == 50 { return d - 1 }
  if op == 51 { return d - 3 }
  if op == 52 { return d }
  if op == 58 { return d - 1 }
  if op == 59 { return d - 1 }
  if op == 60 { return d - 1 }
  if op == 61 { return d - 1 }
  if op == 62 { return d - 1 }
  if op == 63 { return d }
  return d
}

fn max_depth(func_pc: Int) -> Int {
  var pc = func_pc + 2
  var d = 0
  var max_d = 0
  var resetnext = 0
  while pc < ir_len() {
    let op = ir_word(pc)
    if op == 13 { return max_d }
    if op == 57 {
      pc = pc + 3 + ir_word(pc + 1)
    } else {
      if resetnext == 1 { d = 0 resetnext = 0 }
      d = oplen_d_change(op, pc, d)
      if d > max_d { max_d = d }
      if op == 0 { resetnext = 1 }
      if op == 7 { resetnext = 1 }
      if op == 9 { resetnext = 1 }
      pc = pc + 1 + oplen(op)
    }
  }
  return max_d
}

fn emit_cmp(c: Console, d: Int, cond: Text, resolved_next_pc: Int) -> Unit {
  let reg1 = ld_as_int(c, d - 2)
  let reg2 = ld_as_int(c, d - 1)
  let reg3 = get_reg()
  let reg4 = get_reg()
  c.print("  %r") num(c, reg3) c.print(" = icmp ") c.print(cond) c.print(" i64 %r") num(c, reg1) c.print(", %r") num(c, reg2) c.print("\n")
  c.print("  %r") num(c, reg4) c.print(" = zext i1 %r") num(c, reg3) c.print(" to i64\n")
  c.print("  store i64 %r") num(c, reg4) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
  set_sty(d - 2, 0)
  c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
}

fn emit_farith(c: Console, d: Int, instr: Text) -> Unit {
  let a = ld_as_double(c, d - 2)
  let b = ld_as_double(c, d - 1)
  let r = get_reg()
  c.print("  %r") num(c, r) c.print(" = ") c.print(instr) c.print(" double %r") num(c, a) c.print(", %r") num(c, b) c.print("\n")
  st_double(c, d - 2, r)
}

fn emit_fcmp(c: Console, d: Int, cond: Text) -> Unit {
  let a = ld_as_double(c, d - 2)
  let b = ld_as_double(c, d - 1)
  let r1 = get_reg()
  let r2 = get_reg()
  c.print("  %r") num(c, r1) c.print(" = fcmp ") c.print(cond) c.print(" double %r") num(c, a) c.print(", %r") num(c, b) c.print("\n")
  c.print("  %r") num(c, r2) c.print(" = zext i1 %r") num(c, r1) c.print(" to i64\n")
  st_int(c, d - 2, r2)
}

# ---- transcendental preambles: emit_fn.lm's SPEC for exp/ln/pow is its OWN interpreter's
# WAT ($f_exp/$f_ln/$f_pow in seed/lumenc.wat): a Taylor series for exp (range-reduced by ln2,
# 16 terms) and an atanh-series for ln (range-reduced to m in [sqrt(0.5),sqrt2), 15 terms),
# pow(x,y) = exp(y*ln(x)). NOT libm, NOT llvm.exp/llvm.log/llvm.pow: those are approximations
# that do not reproduce the interpreter's bits (verified empirically against the WAT source;
# emit_fn.lm's own C preamble currently calls libm exp/log/pow directly, which is a DIFFERENT,
# already-present divergence in that file that this round does not touch or rely on). Both
# loops here have a fixed, IR-independent trip count, so they are unrolled straight-line rather
# than emitted as an LLVM loop with phi nodes - same instruction order as the WAT, every fadd/
# fmul/fdiv in the same left-to-right operand order as the source, so no reassociation risk even
# under -O3 (verified: clang given raw .ll input does not form fma from separate fmul+fadd
# without an explicit "contract" fast-math flag on the instructions, regardless of -ffp-contract).
fn emit_f_exp(c: Console) -> Unit {
  c.print("define double @lm_f_exp(double %x) {\n")
  c.print("entry:\n")
  c.print("  %d0 = fdiv double %x, 0.6931471805599453\n")
  c.print("  %kf = call double @llvm.roundeven.f64(double %d0)\n")
  c.print("  %k = call i64 @llvm.fptosi.sat.i64.f64(double %kf)\n")
  c.print("  %kc = sitofp i64 %k to double\n")
  c.print("  %kln2 = fmul double %kc, 0.6931471805599453\n")
  c.print("  %r = fsub double %x, %kln2\n")
  var i = 1
  while i <= 16 {
    if i == 1 {
      c.print("  %tm1 = fmul double 1.000000e+00, %r\n")
      c.print("  %term1 = fdiv double %tm1, 1.000000e+00\n")
      c.print("  %sum1 = fadd double 1.000000e+00, %term1\n")
    } else {
      c.print("  %tm") num(c, i) c.print(" = fmul double %term") num(c, i - 1) c.print(", %r\n")
      c.print("  %term") num(c, i) c.print(" = fdiv double %tm") num(c, i) c.print(", ") num(c, i) c.print(".000000e+00\n")
      c.print("  %sum") num(c, i) c.print(" = fadd double %sum") num(c, i - 1) c.print(", %term") num(c, i) c.print("\n")
    }
    i = i + 1
  }
  c.print("  %kadj = add i64 %k, 1023\n")
  c.print("  %kshift = shl i64 %kadj, 52\n")
  c.print("  %scale = bitcast i64 %kshift to double\n")
  c.print("  %res = fmul double %sum16, %scale\n")
  c.print("  ret double %res\n")
  c.print("}\n")
}

fn emit_f_ln(c: Console) -> Unit {
  c.print("define double @lm_f_ln(double %x) {\n")
  c.print("entry:\n")
  c.print("  %isnonpos = fcmp ole double %x, 0.000000e+00\n")
  c.print("  br i1 %isnonpos, label %retzero, label %body\n")
  c.print("retzero:\n")
  c.print("  ret double 0.000000e+00\n")
  c.print("body:\n")
  c.print("  %bits = bitcast double %x to i64\n")
  c.print("  %shr = lshr i64 %bits, 52\n")
  c.print("  %biased = and i64 %shr, 2047\n")
  c.print("  %e0 = sub i64 %biased, 1023\n")
  c.print("  %mant = and i64 %bits, 4503599627370495\n")
  c.print("  %mbits0 = or i64 %mant, 4607182418800017408\n")
  c.print("  %m0 = bitcast i64 %mbits0 to double\n")
  c.print("  %needhalve = fcmp ogt double %m0, 1.4142135623730951\n")
  c.print("  br i1 %needhalve, label %halve, label %noshalve\n")
  c.print("halve:\n")
  c.print("  %m1 = fmul double %m0, 5.000000e-01\n")
  c.print("  %e1 = add i64 %e0, 1\n")
  c.print("  br label %merge\n")
  c.print("noshalve:\n")
  c.print("  br label %merge\n")
  c.print("merge:\n")
  c.print("  %m = phi double [ %m1, %halve ], [ %m0, %noshalve ]\n")
  c.print("  %e = phi i64 [ %e1, %halve ], [ %e0, %noshalve ]\n")
  c.print("  %mm1 = fsub double %m, 1.000000e+00\n")
  c.print("  %mp1 = fadd double %m, 1.000000e+00\n")
  c.print("  %s = fdiv double %mm1, %mp1\n")
  c.print("  %s2 = fmul double %s, %s\n")
  var i = 3
  while i <= 31 {
    if i == 3 {
      c.print("  %term3 = fmul double %s, %s2\n")
      c.print("  %td3 = fdiv double %term3, 3.000000e+00\n")
      c.print("  %sum3 = fadd double %s, %td3\n")
    } else {
      c.print("  %term") num(c, i) c.print(" = fmul double %term") num(c, i - 2) c.print(", %s2\n")
      c.print("  %td") num(c, i) c.print(" = fdiv double %term") num(c, i) c.print(", ") num(c, i) c.print(".000000e+00\n")
      c.print("  %sum") num(c, i) c.print(" = fadd double %sum") num(c, i - 2) c.print(", %td") num(c, i) c.print("\n")
    }
    i = i + 2
  }
  c.print("  %ec = sitofp i64 %e to double\n")
  c.print("  %eln2 = fmul double %ec, 0.6931471805599453\n")
  c.print("  %sum2x = fmul double %sum31, 2.000000e+00\n")
  c.print("  %res = fadd double %eln2, %sum2x\n")
  c.print("  ret double %res\n")
  c.print("}\n")
}

fn emit_f_pow(c: Console) -> Unit {
  c.print("define double @lm_f_pow(double %x, double %y) {\n")
  c.print("entry:\n")
  c.print("  %lx = call double @lm_f_ln(double %x)\n")
  c.print("  %ylx = fmul double %y, %lx\n")
  c.print("  %res = call double @lm_f_exp(double %ylx)\n")
  c.print("  ret double %res\n")
  c.print("}\n")
}

fn emit_op(c: Console, pc: Int, d: Int, func_pc: Int) -> Int {
  let op = ir_word(pc)
  let next_pc = pc + 1 + oplen(op)
  let resolved_next_pc = resolve_pc(next_pc)

  c.print("L") num(c, pc) c.print(":\n")

  if op == 0 {
    c.print("  call void @exit(i32 0)\n  unreachable\n")
    return d
  }
  if op == 1 {
    let val = ir_word(pc + 1)
    c.print("  store i64 ") num(c, val) c.print(", ptr %s") num(c, d) c.print(", align 8\n")
    set_sty(d, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d + 1
  }
  if op == 2 {
    let k = ir_word(pc + 1)
    let t = type_of_slot(func_pc, k)
    let reg = get_reg()
    if t == 1 {
      c.print("  %r") num(c, reg) c.print(" = load double, ptr %F") num(c, k) c.print(", align 8\n")
      c.print("  store double %r") num(c, reg) c.print(", ptr %sd") num(c, d) c.print(", align 8\n")
      set_sty(d, 1)
    } else {
      c.print("  %r") num(c, reg) c.print(" = load i64, ptr %F") num(c, k) c.print(", align 8\n")
      c.print("  store i64 %r") num(c, reg) c.print(", ptr %s") num(c, d) c.print(", align 8\n")
      set_sty(d, 0)
    }
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d + 1
  }
  if op == 3 {
    let reg1 = ld_as_int(c, d - 2)
    let reg2 = ld_as_int(c, d - 1)
    let reg3 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = add i64 %r") num(c, reg1) c.print(", %r") num(c, reg2) c.print("\n")
    c.print("  store i64 %r") num(c, reg3) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 4 {
    let reg1 = ld_as_int(c, d - 2)
    let reg2 = ld_as_int(c, d - 1)
    let reg3 = get_reg()
    c.print("  %r") num(c, reg3) c.print(" = sub i64 %r") num(c, reg1) c.print(", %r") num(c, reg2) c.print("\n")
    c.print("  store i64 %r") num(c, reg3) c.print(", ptr %s") num(c, d - 2) c.print(", align 8\n")
    set_sty(d - 2, 0)
    c.print("  br label %L") num(c, resolved_next_pc) c.print("\n")
    return d - 1
  }
  if op == 5 {
    emit_cmp(c, d, "slt", resolved_next_pc)
    return d - 1
