fn main(console: Console) -> Unit {
  let readings = array(3)
  aset(readings, 0, 1.25)
  aset(readings, 1, 3.75)
  aset(readings, 2, 4.0)
  var total = 0.0
  var idx = 0
  while idx < alen(readings) {
    total = total + aget(readings, idx)
    idx = idx + 1
  }
  console.print_int(round(total * 100.0))
}
