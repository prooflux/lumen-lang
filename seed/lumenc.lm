# Int arrays reuse the Float-array opcodes (49-52, raw i64 slots): "i" prefix + same suffix.
fn is_iapfx(off: Int, len: Int) -> Int {
  if len < 2 { return 0 }
  if load8(off) != 105 { return 0 }
  if load8(off + 1) != 97 { return 0 }
  return 1
}

